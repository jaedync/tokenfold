# Required: API key for authenticating client pushes
STATS_API_KEY=change-me-to-a-random-secret

# Optional: timezone for daily bucketing (default: America/Chicago)
# TZ=America/Chicago

# Optional: SQLite database path (default: /app/data/tokenfold.db)
# DB_PATH=/app/data/tokenfold.db

# Optional: display name shown on the dashboard
# STATS_OWNER=your-name

# Notification relay (optional — all empty = feature disabled)
# Forwards Claude Code hook events to Home Assistant as mobile notifications.
# NOTIFY_TOKEN=change-me-to-a-random-secret
# HA_URL=http://homeassistant.local:8123
# HA_TOKEN=your-long-lived-access-token
# HA_DEVICES=mobile_app_phone1,mobile_app_phone2
